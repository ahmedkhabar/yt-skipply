{
  "manifest_version": 1,
  "name": "YTSkipply - Skip Ads Instantly & Automatically for Youtube",
  "version": "1.0",
  "description": "Quickly and automatically skips YouTube advertisements so you don't have to watch them in their entirety.",
  "author": "Ahmed Khabar",
  "homepage_url": "https://github.com/ahmedkhabar/yt-skipply",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": [
    "scripting"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}